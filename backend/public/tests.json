{
  "tests": [
    {
      "name": "Get all data",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Get teams only",
      "method": "GET",
      "path": "/?resource=teams",
      "expectedStatus": 200
    },
    {
      "name": "Register without nick fails",
      "method": "POST",
      "path": "/",
      "body": {"action": "join_team", "contact": "test@mail.com", "team_id": 1},
      "expectedStatus": 400
    },
    {
      "name": "Join team without team_id fails",
      "method": "POST",
      "path": "/",
      "body": {"action": "join_team", "nick": "TestPlayer", "contact": "test@mail.com"},
      "expectedStatus": 400
    }
  ]
}